# ===================================
# Arivu Application - Environment Variables Template
# ===================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control
# ===================================

# ===================================
# MongoDB Configuration
# ===================================
# MongoDB connection URL
# Local development: mongodb://localhost:27017
# Docker: mongodb://admin:changeme123@mongodb:27017/
# Production: Use your managed MongoDB URL from Emergent or other provider
MONGO_URL=mongodb://admin:changeme123@mongodb:27017/

# MongoDB database name
DB_NAME=arivu_db

# MongoDB root credentials (for Docker only)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme123

# ===================================
# Application Security
# ===================================
# Secret key for JWT token generation
# IMPORTANT: Generate a strong random key for production
# You can generate one with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production

# Admin dashboard access (comma-separated email addresses)
# Only these users can access /admin
ADMIN_EMAILS=your-admin-email@example.com

# ===================================
# CORS Configuration
# ===================================
# Allowed origins for CORS (comma-separated)
# Development: * (all origins)
# Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===================================
# AI Configuration (Google Integrations)
# ===================================
# Gemini Flash Integration
# Get your key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ===================================
# Email Configuration (Resend)
# ===================================
# Used for password reset emails and notifications
# Sign up at https://resend.com and get your API key
# You'll need to verify a domain or use their testing domain
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Email address that password reset emails will be sent from
# Must be from a verified domain in your Resend account
RESEND_FROM_EMAIL=noreply@arivu.app

# Public URL of your application (used for password reset links)
# Development: http://localhost:3000
# Production: https://arivu.app
APP_URL=https://arivu.app

# ===================================
# Frontend Configuration
# ===================================
# The frontend uses a relative /api path behind the nginx proxy.
# No explicit backend URL is needed for production Docker deployments.
# For local development outside Docker, set VITE_API_URL if needed.
# VITE_API_URL=http://localhost:8001

# ===================================
# X (Twitter) Integration
# ===================================
# Master switch: set to true to enable X integration (default: false)
X_INTEGRATION_ENABLED=false
# OAuth 2.0 Confidential Client credentials from X Developer Portal
# 1. Go to https://developer.x.com/en/portal/dashboard
# 2. Create a project + app (or use existing)
# 3. Under "User authentication settings", enable OAuth 2.0
# 4. Set Type: "Web App" (Confidential Client)
# 5. Set Redirect URL to: {APP_URL}/settings?section=connections
# 6. Copy Client ID and Client Secret below
# Required scopes: bookmark.read, tweet.read, users.read, offline.access
X_CLIENT_ID=your_x_client_id_here
X_CLIENT_SECRET=your_x_client_secret_here
# Optional: override redirect URI (defaults to {APP_URL}/settings?section=connections)
# X_REDIRECT_URI=
# Optional: max pages fetched per sync run (default 10, set to 0 for unlimited)
# X_MAX_BOOKMARK_PAGES=10
# Optional: max bookmarks per sync (default 300, set to 0 for unlimited)
# X_MAX_BOOKMARKS=300

# ===================================
# Redis Configuration
# ===================================
# Redis URL for account lockout tracking and ephemeral state
# Docker: redis://redis:6379/0
# Local: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ===================================
# Signup Configuration
# ===================================
# Enable or disable new user registration (default: true for self-hosted)
# Set to false for invite-only mode
SIGNUPS_ENABLED=true

# ===================================
# Encryption Key for DB-Stored API Keys
# ===================================
# API keys configured via the Admin UI (Settings → API Keys) are encrypted
# at rest using a key derived from SECRET_KEY. No additional config needed.
# If you rotate SECRET_KEY, DB-stored API keys must be re-entered via the UI.

# ===================================
# Optional Configuration
# ===================================
# Logging level (debug, info, warning, error)
LOG_LEVEL=info

# ===================================
# Production Deployment Notes
# ===================================
# 1. Always use HTTPS in production
# 2. Set strong SECRET_KEY (minimum 32 characters)
# 3. Restrict CORS_ORIGINS to your actual domain(s)
# 4. Use managed MongoDB with authentication
# 5. Never commit .env file with real credentials
# 6. Use environment variables injection from your deployment platform
# ===================================
